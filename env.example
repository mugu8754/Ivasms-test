# 🔐 IVASMS OTP Bot - Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to Git!

# ════════════════════════════════════════════════════════════════
# TELEGRAM CONFIGURATION (REQUIRED)
# ════════════════════════════════════════════════════════════════

# Your Telegram Bot Token
# Get from @BotFather on Telegram
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (Admin ID)
# Get from @userinfobot on Telegram
# Format: 987654321
ADMIN_ID=your_admin_id_here

# ════════════════════════════════════════════════════════════════
# IVASMS CONFIGURATION (REQUIRED)
# ════════════════════════════════════════════════════════════════

# Your ivasms account email
# Get from: https://ivasms.com
IVASMS_EMAIL=your_ivasms_email@example.com

# Your ivasms account password
IVASMS_PASSWORD=your_ivasms_password_here

# ════════════════════════════════════════════════════════════════
# OPTIONAL SETTINGS
# ════════════════════════════════════════════════════════════════

# OTP timeout in seconds (default: 20)
OTP_TIMEOUT_SECONDS=20

# Enable debug logging (true/false, default: false)
DEBUG=false
